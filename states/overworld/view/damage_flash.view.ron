#![enable(implicit_some)]
// Chase mode damage HUD UI (HP bar and HP text)
// 追逐战模式受伤 HUD UI（血条和血量文字）
// Adjusted for Overworld resolution (smaller visible area than Battle)
// 针对 Overworld 分辨率调整（可见区域比 Battle 小）
// With resolution_scale=2, visible area is ±160x±120
// 当 resolution_scale=2 时，可见区域为 ±160x±120
(
    roots: [
        // HUD Info - Pure container node with HP bar and HP text
        // HUD 信息 - 带有血条和血量文字的纯容器节点
        (
            name: "ChaseHUD",
            camera_anchored: true,
            texts: [
                (
                    id: "PlayerName",
                    content: "{$player:name}",
                    font: BattleHud,
                    world_scale: (24.0, 24.0),
                    color: (1.0, 1.0, 1.0, 1.0),
                    transform: (
                        translation: (-145.0, -97.0, 501.0),
                    ),
                ),
                (
                    id: "PlayerLevelLabel",
                    content: "{{battle/ui:LV}}",
                    font: BattleHud,
                    world_scale: (24.0, 24.0),
                    color: (1.0, 1.0, 1.0, 1.0),
                    transform: (
                        translation: (-93.0, -97.0, 501.0),
                    ),
                ),
                (
                    id: "PlayerLevelValue",
                    content: "{$player:lv}",
                    font: BattleHud,
                    world_scale: (24.0, 24.0),
                    color: (1.0, 1.0, 1.0, 1.0),
                    transform: (
                        translation: (-74.0, -97.0, 501.0),
                    ),
                ),
                (
                    id: "HPValueCurrent",
                    content: "{$player:hp}",
                    font: BattleHud,
                    world_scale: (24.0, 24.0),
                    color: (1.0, 1.0, 1.0, 1.0),
                    transform: (
                        translation: ("-3.0 + ($player:hp_max - 20) * 47.0 / 79", -97.0, 501.0),
                    ),
                ),
                (
                    id: "HPSeparator",
                    content: "/",
                    font: BattleHud,
                    world_scale: (24.0, 24.0),
                    color: (1.0, 1.0, 1.0, 1.0),
                    transform: (
                        translation: ("17.0 + ($player:hp_max - 20) * 47.0 / 79", -97.0, 501.0),
                    ),
                ),
                (
                    id: "HPValueMax",
                    content: "{$player:hp_max}",
                    font: BattleHud,
                    world_scale: (24.0, 24.0),
                    color: (1.0, 1.0, 1.0, 1.0),
                    transform: (
                        translation: ("29.0 + ($player:hp_max - 20) * 47.0 / 79", -97.0, 501.0),
                    ),
                ),
            ],
            children: [
                (
                    name: "HPSprite",
                    sprite: (
                        visual: "assets/textures/battle/view/hpname.png",
                        transform: (
                            translation: (-32.0, -105.0, 501.0),
                        ),
                    ),
                ),
                (
                    name: "HPBar",
                    sprite: (
                        visual: "procedural://white_pixel",
                        transform: (
                            translation: (-22.0, -105.0, 501.0),
                            scale: ("12.5 + ($player:hp_max - 20) * 47.5 / 79", 10.0, 1.0),
                        ),
                        // New material system for player HP bar (overworld version)
                        // 新的材质系统用于玩家 HP 条（地图版本）
                        material: (
                            shader: "shared/shaders/hp_bar_sprite.wgsl",
                            params: {
                                "hp_ratio": Expr("$player:hp / $player:hp_max"),
                                "lag_ratio": Static(1.0),
                                "half_width": Expr("20.0 + ($player:hp_max - 20) * 47.5 / 79 / 2"),
                                "alpha": Static(1.0),
                            },
                            animations: (
                                lag: (
                                    source: "hp_ratio",
                                    target: "lag_ratio",
                                    delay: 0.2,
                                    duration: 0.4,
                                    easing: OutCirc,
                                ),
                            ),
                        ),
                        pivot: (0.0, 0.5),
                    ),
                ),
            ],
        ),
    ]
)
