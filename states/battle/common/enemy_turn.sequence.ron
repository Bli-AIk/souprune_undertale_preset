#![enable(implicit_some)]
// Preset template: Enemy Turn Phase
// 预设模板：敌方回合阶段
//
// Handles one enemy turn cycle:
//   1. Spawn the battle player
//   2. Pick and run the enemy's turn sequence via PickEnemyTurn
//      (turn sequences are responsible for battle box sizing, danmaku, and timing)
//   3. Despawn the player
//
// 处理一个敌人回合周期：
//   1. 生成战斗玩家
//   2. 通过 PickEnemyTurn 选择并运行敌人的回合序列
//     （回合序列负责战斗框缩放、弹幕和计时）
//   3. 移除玩家
//
// Parameters (injected via RunSequence params → local facts):
//   _param_enemy_id       — enemy id for turn selection (required)
//
// 参数：
//   _param_enemy_id       — 用于回合选择的敌人 id（必需）
//
// Usage / 使用方式:
//   RunSequence(
//       path: "states/battle/common/enemy_turn.sequence.ron",
//       params: { "enemy_id": String("mad_dummy") },
//   )
(chapters: [
    // Spawn battle player
    // 生成战斗玩家
    SetPlayer(Spawn(
        config_path: "states/battle/players/player.battle_player.ron",
        position: (0.0, -80.0),
    )),

    // Pick and run the enemy's turn sequence
    // 选择并运行敌人的回合序列
    PickEnemyTurn(enemy_id_fact: "_param_enemy_id"),

    // Despawn player after turn
    // 回合结束后移除玩家
    Sequence([
        Wait(0.5),
        SetPlayer(Despawn),
    ]),
])
