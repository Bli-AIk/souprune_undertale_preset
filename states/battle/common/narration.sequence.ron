// Generic narration sequence with Mortar dialogue
// 通用 Mortar 对话旁白序列
//
// This sequence displays a narration message using Mortar dialogue system,
// supporting multi-step dialogue with typewriter effect.
// The narration node is determined by the `action_param` fact, and the mortar
// file path by `mortar_path` fact - both set by FRE rules before running this sequence.
//
// 此序列使用 Mortar 对话系统显示旁白消息，支持带打字机效果的多步对话。
// 旁白节点由 `action_param` fact 确定，mortar 文件路径由 `mortar_path` fact 确定，
// 两者都在运行此序列前由 FRE 规则设置。
//
// Prerequisites / 前置条件:
//   - action_param: The Mortar node name for the dialogue (set by FRE)
//   - mortar_path: The Mortar file path relative to shared/locales/{locale}/ (set by FRE)
//
// This is a reusable template for any "show dialogue → wait for completion" pattern.
// 这是任何"显示对话 → 等待完成"模式的可复用模板。
(chapters: [
    // Stop any playing intro dialogue before showing narration
    // 在显示旁白前停止任何正在播放的开场对话
    EmitFactEvent(event_id: "dialogue:stop"),

    // Disable typewriter replay when depth returns to 0 (controlled by FRE, not hardcoded)
    // 禁用 depth 返回 0 时的打字机重播（由 FRE 控制，非硬编码）
    SetViewFact(key: "dialogue:replay_on_resume", value: Bool(false)),

    // Hide menu buttons, show narration area
    // 隐藏菜单按钮高亮，显示旁白区域
    SetViewFact(key: "depth", value: Int(0)),
    SetViewFact(key: "buttons_visible", value: Bool(false)),
    SetViewFact(key: "narration_visible", value: Bool(true)),

    // Start Mortar dialogue using the node name from action_param
    // and the path from mortar_path (both set by FRE rules before running this sequence)
    // 使用 action_param 中的节点名和 mortar_path 中的路径启动 Mortar 对话
    // （两者都在运行此序列前由 FRE 规则设置）
    ModifyFact(
        modifications: [
            Set(key: "dialogue:pending_mortar_path", value: Expr("$mortar_path")),
            Set(key: "dialogue:pending_mortar_node", value: Expr("$action_param")),
            Set(key: "dialogue:pending_start", value: Bool(true)),
            Set(key: "dialogue:has_typewriter", value: Bool(true)),
            Set(key: "dialogue:has_focus", value: Bool(true)),
            Set(key: "dialogue:voice", value: String("audios/voice/voice_typewriter_default.wav")),
        ],
    ),

    // Wait for dialogue to start
    // 等待对话开始
    AwaitFact(condition: "$dialogue:active == true", local: false),

    // Wait for dialogue to end (Mortar dialogue finished)
    // 等待对话结束（Mortar 对话完成）
    AwaitFact(condition: "$dialogue:active == false", local: false),

    // Hide narration, restore UI, and clear dialogue text
    // 隐藏旁白，恢复 UI，并清除对话文本
    SetViewFact(key: "narration_visible", value: Bool(false)),
    SetViewFact(key: "buttons_visible", value: Bool(true)),
    SetViewFact(key: "dialogue_text", value: String("")),

    // Re-enable typewriter replay for normal menu navigation
    // 重新启用打字机重播以支持正常菜单导航
    SetViewFact(key: "dialogue:replay_on_resume", value: Bool(true)),
])
