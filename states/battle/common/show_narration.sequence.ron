// 通用序列：显示旁白文本
// 参数: _param_narration_key - Mortar 节点名（通过 RunSequence params 注入）
//
// 使用方式:
// RunSequence(
//     path: "states/battle/common/show_narration.sequence.ron",
//     params: { "narration_key": String("EnemyDummyActCheckResult") },
// )
(chapters: [
    // 显示旁白区域
    SetViewFact(key: "narration_visible", value: Bool(true)),
    
    // 等待玩家按确认键
    AwaitFact(condition: "$confirm_pressed == true"),
    
    // 重置确认标志
    SetViewFact(key: "confirm_pressed", value: Bool(false)),
])
