#![enable(implicit_some)]
// Preset template: Player Turn Phase
// 预设模板：玩家回合阶段
//
// Handles one player turn cycle:
//   1. Enable menu interaction
//   2. Wait for the player to confirm a selection
//   3. Execute the pending action sequence
//   4. End view interaction
//
// 处理一个玩家回合周期：
//   1. 启用菜单交互
//   2. 等待玩家确认选择
//   3. 执行待处理的行动序列
//   4. 结束视图交互
//
// Usage / 使用方式:
//   RunSequence(path: "states/battle/common/player_turn.sequence.ron")
(chapters: [
    // Enable menu interaction
    // 启用菜单交互
    SetViewFact(key: "interactable", value: Bool(true)),
    SetViewFact(key: "depth", value: Int(0)),
    SetViewFact(key: "button_selection", value: Int(0)),

    // Wait for player to confirm selection in submenu
    // 等待玩家在子菜单中确认选择
    AwaitFact(condition: "$selection_confirmed == true"),

    // Reset selection_confirmed for next turn
    // 重置 selection_confirmed 以备下一回合
    SetViewFact(key: "selection_confirmed", value: Bool(false)),

    // Execute the pending action sequence (set by FRE rules)
    // 执行待处理的行动序列（由 FRE 规则设置）
    RunSequence(path_fact: "pending_sequence"),

    // End view interaction (disable menu, hide buttons, etc.)
    // 结束视图交互（禁用菜单、隐藏按钮等）
    RunSequence(path: "states/battle/common/end_view_interaction.sequence.ron"),
])
