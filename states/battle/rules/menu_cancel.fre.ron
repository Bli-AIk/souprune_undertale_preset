#![enable(implicit_some)]
// Battle Menu Cancel Rules — cancel key logic
// 战斗菜单取消规则 — 取消键逻辑

(
    scope: View,

    enums: {
        "depth": ["main", "submenu", "options"],
    },

    rules: [
        // Cancel: ACT/MERCY options → submenu
        (event: ActionEvent(action: "Cancel", kind: JustPressed),
         conditions: ["$interactable == true", "$depth == 'options'"],
         actions: [SetLocalFact("depth", Enum("submenu")), SetLocalFact("act_selection", Int(0)), SetLocalFact("mercy_selection", Int(0))],
         consume_event: true, priority: 100),

        // Cancel: submenu → main menu
        (event: ActionEvent(action: "Cancel", kind: JustPressed),
         conditions: ["$interactable == true", "$depth == 'submenu'"],
         actions: [SetLocalFact("depth", Enum("main")), SetLocalFact("enemy_selection", Int(0)), SetLocalFact("enemy_view_offset", Int(0)), SetLocalFact("item_selection", Int(0))],
         consume_event: true, priority: 100),
    ],
)
