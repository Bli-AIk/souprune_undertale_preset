// ============================================================================
// Auto-Pause Configuration / 自动停顿配置
// ============================================================================
//
// Supports punctuation AND control characters like "\n" (newline).
// All newline sources (line:, """, \n) are unified as "\n" in the typewriter.
// 支持标点和控制字符如 "\n"（换行）。
// 所有换行来源（line:、"""、\n）在打字机中统一为 "\n"。
//
// Usage in .mortar files / 在 .mortar 文件中的用法:
//
//   fn pause_typewriter(duration: Number)
//   fn resume_typewriter()
//
//   node Example {
//       text: "这段文字，会在逗号后停顿……然后继续。"
//       // ↑ Auto-pause handles this automatically based on the preset below.
//       // ↑ 自动停顿会根据下方预设自动处理。
//
//       // Multi-line text also pauses at newlines / 多行文本也会在换行处停顿:
//       line: "第一行"
//       line: "第二行"
//       // ↑ Pauses between lines per "\n" duration in the preset.
//       // ↑ 行间停顿按预设中 "\n" 的时长。
//
//       // Manual timed pause via event / 通过事件手动定时停顿:
//       text: "到这个字停一下。然后继续说。"
//       with events: [ 7, pause_typewriter(0.5) ]
//   }
//
// Switching presets at runtime / 运行时切换预设:
//   Set FRE Fact "dialogue:auto_pause_preset" to the preset name.
//   设置 FRE Fact "dialogue:auto_pause_preset" 为预设名。
//   e.g. in .fre.ron rule actions: SetLocalFact("dialogue:auto_pause_preset", "dramatic")
//
// Disabling auto-pause / 关闭自动停顿:
//   Set FRE Fact "dialogue:auto_pause_enabled" to false.
//   设置 FRE Fact "dialogue:auto_pause_enabled" 为 false。
//
// ============================================================================
(
    // Name of the default preset to use when no FRE override is active.
    // 无 FRE 覆盖时使用的默认预设名称。
    default_preset: "normal",

    // Named presets: each maps characters → pause duration (seconds).
    // Supports punctuation and control characters like "\n" (newline).
    // 命名预设：每个将字符映射为停顿时长（秒）。
    // 支持标点和控制字符如 "\n"（换行）。
    presets: {
        // Standard preset for general dialogue.
        // 通用对话的标准预设。
        "normal": {
            "\n": 0.2,
            "。": 0.3,
            "，": 0.15,
            "！": 0.35,
            "？": 0.35,
            "…": 0.4,
            "、": 0.1,
            "；": 0.2,
            "：": 0.2,
            ".": 0.3,
            ",": 0.15,
            "!": 0.35,
            "?": 0.35,
            ";": 0.2,
            ":": 0.2,
        },
        // Slower preset — longer pauses for dramatic or emotional scenes.
        // 慢速预设——用于戏剧性或情感场景的更长停顿。
        "dramatic": {
            "\n": 0.35,
            "。": 0.5,
            "，": 0.25,
            "！": 0.6,
            "？": 0.6,
            "…": 0.8,
            "、": 0.15,
            "；": 0.3,
            "：": 0.3,
            ".": 0.5,
            ",": 0.25,
            "!": 0.6,
            "?": 0.6,
            ";": 0.3,
            ":": 0.3,
        },
        // Fast preset — brief pauses for fast-talking characters.
        // 快速预设——用于语速快的角色的简短停顿。
        "fast": {
            "\n": 0.1,
            "。": 0.15,
            "，": 0.08,
            "！": 0.2,
            "？": 0.2,
            "…": 0.25,
            ".": 0.15,
            ",": 0.08,
            "!": 0.2,
            "?": 0.2,
        },
    },
)
