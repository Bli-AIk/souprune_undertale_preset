#![enable(implicit_some)]

// State configuration for the game.
// 游戏状态配置。
//
// This file defines the behavior for each game state, including:
// - Whether UI is interactive
// - Whether the player can move
// - View layouts to load
// - Sounds to play on state transitions
//
// 此文件定义每个游戏状态的行为，包括：
// - UI 是否可交互
// - 玩家是否可移动
// - 要加载的视图布局
// - 状态转换时播放的声音

StateConfig(
    states: {
        // Normal exploration state - player can move freely
        // 正常探索状态 - 玩家可自由移动
        "Normal": (
            view_interactive: false,
            player_movable: true,
            view_layout: None,
            initial_layer: None,
        ),

        // Backpack menu state - UI is active, player cannot move
        // 背包菜单状态 - UI 激活，玩家不能移动
        // Note: Navigation is now handled by FRE rules and initial_facts in the view_layout
        // 注意：导航现在由 FRE 规则和 view_layout 中的 initial_facts 处理
        "Backpack": (
            view_interactive: true,
            player_movable: false,
            view_layout: "states/overworld/view/undertale_backpack.view.ron",
            initial_layer: None,  // No longer needed - using initial_facts in view_layout
            on_enter_sound: "audios/sfx/confirm.wav",
            //on_exit_sound: "audios/sfx/choice.wav",
        ),

        // Cutscene state - player cannot move, UI is inactive
        // 过场动画状态 - 玩家不能移动，UI 不活动
        "Cutscene": (
            view_interactive: false,
            player_movable: false,
            view_layout: None,
            initial_layer: None,
        ),

        // Chase state - darkened screen with highlights, player can move but cannot interact
        // 追逐战状态 - 屏幕变暗，高亮显示，玩家可移动但不能交互
        "Chase": (
            view_interactive: false,
            player_movable: true,
            player_can_interact: false,
            view_layout: None,
            initial_layer: None,
            chase_config: "states/overworld/chase_config.ron",
        ),

        // Dialogue state - talking to NPCs, player cannot move
        // 对话状态 - 与 NPC 交谈，玩家不能移动
        // View is spawned dynamically via SpawnView FRE action
        // View 通过 SpawnView FRE action 动态生成
        "Dialogue": (
            view_interactive: false,
            player_movable: false,
            view_layout: None,
            initial_layer: None,
        ),
    },
)
