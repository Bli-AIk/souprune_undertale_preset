#![enable(implicit_some)]
// UI Box Structure Definition
// This file defines the classic Undertale-style UI box with border and filler.
// UI 盒子结构定义
// 此文件定义经典 Undertale 风格的带边框和填充的 UI 盒子。
//
// Structure:
// 1. UIBoxBorder - White outer rectangle (uses Outer SDF)
// 2. UIBoxFiller - Black inner rectangle, child of border (uses Inner SDF)
//
// 结构：
// 1. UIBoxBorder - 白色外部矩形（使用外部 SDF）
// 2. UIBoxFiller - 黑色内部矩形，边框的子节点（使用内部 SDF）
(
    layer_count: 2,
    root: (
        name: "UIBoxBorder",
        sdf_type: Outer,
        color_source: White,
        z_offset: 5.0,
        is_filler: false,
        children: [
            (
                name: "UIBoxFiller",
                sdf_type: Inner,
                color_source: FillColor,
                z_offset: 0.1,
                is_filler: true,
                children: [],
            ),
        ],
    ),
)