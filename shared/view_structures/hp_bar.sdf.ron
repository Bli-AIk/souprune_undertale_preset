#![enable(implicit_some)]
// HP Bar Structure Definition
// Defines a two-layer HP bar: background (red) and foreground (yellow)
// HP 条结构定义
// 定义双层HP条：背景（红色）和前景（黄色）
(
    layer_count: 2,
    root: (
        name: "HPBarBackground",
        sdf_type: Inner,
        color_source: Custom((r: 1.0, g: 0.0, b: 0.0, a: 1.0)),  // Red
        z_offset: 0.0,
        is_filler: false,
        children: [
            (
                name: "HPBarForeground",
                sdf_type: Inner,
                color_source: Custom((r: 1.0, g: 1.0, b: 0.0, a: 1.0)),  // Yellow
                z_offset: 0.1,
                is_filler: true,
                children: [],
            ),
        ],
    ),
)
