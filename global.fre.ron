#![enable(implicit_some)]
// Player Data Rules - Global Layer Facts
// 玩家数据规则 - 全局层事实
//
// This file defines the initial player data that is loaded into the FRE
// LayeredFactDatabase at startup. All player attributes are stored as facts
// rather than hardcoded in Rust code.
//
// 此文件定义启动时加载到 FRE LayeredFactDatabase 的初始玩家数据。
// 所有玩家属性作为事实存储，而非在 Rust 代码中硬编码。
//
// These facts are loaded into the GLOBAL layer and persist across game states.
// For save/load functionality, simply serialize/deserialize these facts.
//
// 这些事实加载到全局层并在游戏状态间持久化。
// 对于存档/读档功能，只需序列化/反序列化这些事实即可。

(
    // Scope: Global - facts and rules persist for app lifetime
    // 作用域：Global - 事实和规则在应用生命周期内持久化
    scope: Global,

    // Initial player facts - these become the player's starting stats
    // 初始玩家事实 - 这些成为玩家的初始属性
    facts: {
        // Basic identity
        // 基本身份
        "player:name": String("Chara"),

        // Level progression
        // 等级进度
        "player:lv": Int(1),
        "player:exp": Int(0),
        "player:next_exp": Int(10),

        // Health
        // 生命值
        "player:hp": Int(20),
        "player:hp_max": Int(20),

        // Combat stats
        // 战斗属性
        "player:atk": Int(0),
        "player:def": Int(0),

        // Currency
        // 货币
        "player:gold": Int(42),

        // Equipment (item IDs)
        // 装备（物品 ID）
        "player:weapon": String("stick"),
        "player:armor": String("bandage"),

        // Inventory (StringList of item IDs)
        // 物品栏（物品 ID 的字符串列表）
        "player:inventory": StringList([
            "monster_candy",
            "monster_candy",
            "monster_candy",
            "monster_candy",
            "monster_candy",
            "UNDEFITEM",
        ]),
        "player:inventory_capacity": Int(8),
    },

    // No rules in this file - purely data definition
    // 此文件无规则 - 纯数据定义
    rules: [],
)
